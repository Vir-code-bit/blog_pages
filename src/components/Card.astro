---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className = '' } = Astro.props;
const Element = href ? 'a' : 'div';
---

<Element
  href={href}
  class={`block bg-white rounded-md3-lg p-6 shadow-md3-1 hover:shadow-md3-3 transition-shadow duration-300 border border-transparent hover:border-google-surfaceContainer ${className}`}
>
  <slot />
</Element>
