---
const links = [
  { name: '主页', href: '/blog_pages/' },
  { name: '文章', href: '/blog_pages/blog' },
  { name: '项目', href: '/blog_pages/projects' },
  { name: '实验室', href: '/blog_pages/lab' },
  { name: '关于', href: '/blog_pages/about' },
];
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-google-surfaceContainer shadow-sm transition-all duration-300">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl h-16 flex items-center justify-between">
    <a href="/blog_pages/" class="text-xl font-bold text-google-blue tracking-tight hover:opacity-80 transition-opacity">
      MySite
    </a>
    <nav class="hidden md:flex gap-1">
      {links.map(link => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 ${
              isActive 
                ? 'bg-google-blue/10 text-google-blue' 
                : 'text-google-onSurfaceVariant hover:bg-google-surfaceContainer hover:text-google-onSurface'
            }`}
          >
            {link.name}
          </a>
        )
      })}
    </nav>
  </div>
</header>
