---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="文章 | MySite">
  <header class="mb-10 px-2">
    <h1 class="text-4xl font-bold mb-4">文章</h1>
    <p class="text-google-onSurfaceVariant">分享技术心得、设计思考与生活感悟。</p>
  </header>

  <div class="relative border-l-2 border-google-surfaceContainer ml-4 md:ml-6 space-y-8 pb-8">
    {posts.map(post => (
      <div class="relative pl-8 md:pl-10">
        <div class="absolute w-4 h-4 bg-google-blue rounded-full -left-[9px] top-6 border-4 border-google-surface"></div>
        <Card href={`/blog_pages/blog/${post.slug}`} class="hover:-translate-y-1 transition-transform duration-300">
          <div class="flex flex-wrap gap-2 mb-3">
            {post.data.tags.map((tag: string) => (
              <span class="px-2 py-1 bg-google-surfaceContainer text-google-onSurfaceVariant text-xs rounded-md3-sm font-medium">
                #{tag}
              </span>
            ))}
          </div>
          <h2 class="text-2xl font-bold mb-2 text-google-onSurface">{post.data.title}</h2>
          <p class="text-google-onSurfaceVariant mb-4 line-clamp-2">{post.data.description}</p>
          <div class="flex items-center text-sm text-google-outline gap-4">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span>预计阅读 {Math.ceil(post.body.length / 400)} 分钟</span>
          </div>
        </Card>
      </div>
    ))}
  </div>
</Layout>
